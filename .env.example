# atomno-mcp-zakupki — пример конфигурации
# Скопируйте в `.env` и заполните нужные провайдеры. Для сетевых тулзов
# нужен хотя бы один API-ключ; без ключей работает только lookup_okpd2.

# --- Логирование ---
# DEBUG | INFO | WARNING | ERROR | CRITICAL
MCP_ZAKUPKI_LOG_LEVEL=INFO

# --- Кэш ---
# Путь к SQLite-файлу с кэшем поиска / карточек / справочника ОКПД2.
# По умолчанию — `mcp_zakupki_cache.sqlite` в текущей рабочей директории.
# MCP_ZAKUPKI_CACHE_DB=/var/lib/mcp-zakupki/cache.sqlite

# --- Цепочка провайдеров (по умолчанию: damia,gosplan,navodki — API only) ---
# MCP_ZAKUPKI_PROVIDERS=damia,gosplan,navodki
# Opt-in HTML-парсинг (не рекомендуется для production):
# MCP_ZAKUPKI_PROVIDERS=damia,gosplan,navodki,html_fallback

# --- DaMIA API-Закупки (https://damia.ru/apizakupki) ---
# Зарегистрируйте API-ключ на damia.ru. Бесплатный тариф «DaMIA-API-Старт»
# даёт ~100 запросов/мес для тестирования.
# MCP_ZAKUPKI_DAMIA_KEY=

# --- ГосПлан API v2 (https://wiki.gosplan.info) ---
# API-Key вместо JWT (v2). Sandbox: fz44test.gosplan.info.
# MCP_ZAKUPKI_GOSPLAN_KEY=
# MCP_ZAKUPKI_GOSPLAN_BASE=https://v2.gosplan.info

# --- navodki.ru ---
# REST-агрегатор поверх ЕИС. Free-тариф ограниченный.
# MCP_ZAKUPKI_NAVODKI_KEY=

# --- ЕИС-официальный (через токен Минфина) ---
# Включается через extra: pip install atomno-mcp-zakupki[eis-official]
# Требует установки сертификата Минфина и токена через
# https://zakupki.gov.ru/pmd/auth/welcome (НЕ через eruz.zakupki.gov.ru).
# MCP_ZAKUPKI_EIS_TOKEN=
# MCP_ZAKUPKI_EIS_BASE=https://int.zakupki.gov.ru/eis-integration/services

# --- Pro-режим (api.atomno-mcp.ru/zakupki/) ---
# Активирует Pro-tools (summarize_tender_risks, predict_win_probability,
# subscribe_watchlist, ask_44fz_223fz, batch_search_tenders).
# Получите ключ в личном кабинете app.atomno-labs.ru/zakupki (после запуска).
# MCP_ZAKUPKI_API_KEY=

# --- Лимиты ---
# Запросов в минуту со стороны клиента (защита провайдера и нашей квоты).
# MCP_ZAKUPKI_RPS=30

# --- Прокси / User-Agent ---
# MCP_ZAKUPKI_HTTP_PROXY=
# MCP_ZAKUPKI_USER_AGENT=atomno-mcp-zakupki/0.1.0 (+https://atomno-labs.ru/contact)
